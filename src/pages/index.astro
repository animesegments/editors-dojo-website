---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CredibilityStrip from '../components/CredibilityStrip.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ContactCTA from '../components/ContactCTA.astro';
import TestimonialsArchived from '../components/TestimonialsArchived.astro';
import { portfolioItems } from '../data/portfolio';
import { services } from '../data/services';
---

<BaseLayout path="/">
  <Hero />
  <CredibilityStrip />

  <section class="section portfolio-preview-section" data-animate>
    <div class="container">
      <SectionHeader
        label="01 — Portfolio"
        title="Selected edits"
        subtitle="A small collection of crafted edits, sample work, and practice pieces."
        supporting="No fake claims. No overhyped results. Just real edits that show the style, pacing, and attention to detail behind editorsdojo."
      />
      <div class="divider"><span></span></div>
      <PortfolioPreview items={portfolioItems} />
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container">
      <SectionHeader
        label="02 — Services"
        title="Editing styles for personal brands"
        subtitle="Two clean editing styles built for Reels, TikTok, and YouTube Shorts."
      />
      <div class="divider"><span></span></div>
      <div class="services-grid" data-stagger>
        {services.map((service, i) => (
          <ServiceCard
            number={service.number}
            title={service.title}
            description={service.homeDescription}
            index={i}
          />
        ))}
      </div>
      <p class="text-center mt-2">
        <a href="/services" class="link-arrow">Learn more about services →</a>
      </p>
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container">
      <SectionHeader
        label="03 — Process"
        title="From raw clip to polished edit"
        subtitle="A simple process made to keep things easy from the first message to the final video."
      />
      <div class="divider"><span></span></div>
      <div data-stagger>
        <ProcessSteps />
      </div>
    </div>
  </section>

  <ContactCTA />
  <TestimonialsArchived />
</BaseLayout>