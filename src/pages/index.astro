---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CredibilityStrip from '../components/CredibilityStrip.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ContactCTA from '../components/ContactCTA.astro';
import TestimonialsArchived from '../components/TestimonialsArchived.astro';
import { portfolioItems } from '../data/portfolio';
---

<BaseLayout path="/">
  <Hero />
  <CredibilityStrip />

  <section class="section portfolio-preview-section" data-animate>
    <div class="container">
      <SectionHeader
        label="01 — Portfolio"
        title='Selected <span class="accent-script">crafted</span> edits'
        subtitle="Portfolio pieces and sample work — no inflated claims."
      />
      <div class="divider"><span></span></div>
      <PortfolioPreview items={portfolioItems} />
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container">
      <SectionHeader
        label="02 — Services"
        title="Cinematic edits for personal brands"
        subtitle="Simple, sharp, and story-driven. Built for Reels, TikTok, and YouTube Shorts."
      />
      <div class="divider"><span></span></div>
      <div class="services-grid" data-stagger>
        <ServiceCard
          number="01"
          title="Short-Form Video Editing"
          description="Clean, engaging edits for Reels, TikTok, and YouTube Shorts."
          index={0}
        />
        <ServiceCard
          number="02"
          title="Cinematic Personal Brand Edits"
          description="Premium storytelling edits for creators, coaches, entrepreneurs, and educators."
          index={1}
        />
        <ServiceCard
          number="03"
          title="Free Sample Edit"
          description="Send me a raw clip and I'll create a short sample so you can see the editing style before working together."
          index={2}
        />
      </div>
      <p class="text-center mt-2">
        <a href="/services" class="link-arrow">Learn more about services →</a>
      </p>
    </div>
  </section>

  <section class="section" data-animate>
    <div class="container">
      <SectionHeader
        label="03 — Process"
        title='Edit with <span class="accent-script">precision</span>'
        subtitle="A straightforward path from raw footage to polished short-form content."
      />
      <div class="divider"><span></span></div>
      <div data-stagger>
        <ProcessSteps />
      </div>
    </div>
  </section>

  <ContactCTA />
  <TestimonialsArchived />
</BaseLayout>