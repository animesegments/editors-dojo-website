---
import BaseLayout from '../layouts/BaseLayout.astro';
import OwnedMedia from '../components/OwnedMedia.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Logo from '../components/Logo.astro';
---

<BaseLayout
  title="editorsdojo | About"
  description="About editorsdojo — a freelance video editing brand built around discipline, clean visuals, and strong storytelling."
  path="/about"
>
  <header class="page-header">
    <div class="container">
      <span class="section-label">About</span>
      <h1 class="section-title">The dojo behind the edits</h1>
    </div>
  </header>

  <section class="section" style="padding-top: 0;">
    <div class="container about-grid">
      <div class="about-content">
        <p>
          editorsdojo is a freelance video editing brand built around discipline, clean visuals, and strong storytelling.
        </p>
        <p>
          The goal is simple: take raw footage and turn it into short-form content that looks premium, keeps attention, and helps personal brands show up better online.
        </p>
        <p>
          I'm focused on helping creators, coaches, entrepreneurs, and personal brands improve the way their videos look, feel, and flow.
        </p>

        <div class="pull-quote">
          <p>Built for attention, clarity, and trust.</p>
        </div>
      </div>

      <div class="about-visual">
        <div class="about-logo-wrap">
          <div class="about-logo-glow" aria-hidden="true"></div>
          <Logo class="about-logo-img brand-logo" width={220} height={220} />
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container">
      <OwnedMedia />
    </div>
  </section>

  <ContactCTA />
</BaseLayout>