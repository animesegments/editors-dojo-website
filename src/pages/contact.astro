---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE } from '../data/site';
---

<BaseLayout
  title="editorsdojo | Contact"
  description="Contact editorsdojo for a free sample edit. Short-form video editing for creators and personal brands."
  path="/contact"
>
  <header class="page-header">
    <div class="container">
      <span class="section-label">Contact</span>
      <h1 class="section-title">Want your raw video turned into a clean short-form edit?</h1>
      <p class="section-subtitle">
        Fill out the form or reach out directly.
      </p>
      <p class="section-supporting">
        Tell me what you need edited, what style you like, and what you want the video to do. I'll take a look and get back to you.
      </p>
    </div>
  </header>

  <section class="section" style="padding-top: 0;">
    <div class="container contact-layout">
      <ContactForm />

      <aside class="contact-info">
        <h3>Direct Contact</h3>

        <div class="contact-info-item">
          <p class="label">Email</p>
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </div>

        <div class="contact-info-item">
          <p class="label">Instagram</p>
          <a href={SITE.instagram.editorsdojo} target="_blank" rel="noopener noreferrer">@editorsdojo</a>
        </div>

        <p class="contact-note">
          Prefer email? Reach out directly. No form needed.
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>