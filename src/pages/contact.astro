---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE } from '../data/site';
---

<BaseLayout
  title="editorsdojo | Contact"
  description="Contact editorsdojo for a free sample edit. Short-form video editing for creators and personal brands."
  path="/contact"
>
  <header class="page-header page-header--contact">
    <div class="container">
      <span class="section-label">Contact</span>
      <h1 class="section-title">Book your free sample edit</h1>
      <p class="section-subtitle">
        A few quick taps — no long forms.
      </p>
      <p class="section-supporting">
        Choose your options step by step. Only name and email at the end.
      </p>
    </div>
  </header>

  <section class="section contact-section" style="padding-top: 0;">
    <div class="contact-layout contact-layout--typeform">
      <ContactForm />

      <p class="contact-typeform-note text-center">
        Prefer Instagram? <a href={SITE.instagram.editorsdojo} target="_blank" rel="noopener noreferrer">@editorsdojo</a>
      </p>
    </div>
  </section>
</BaseLayout>