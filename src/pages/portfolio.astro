---
import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { portfolioItems } from '../data/portfolio';
---

<BaseLayout
  title="editorsdojo | Portfolio"
  description="View sample edits and portfolio pieces by editorsdojo — cinematic short-form video editing for personal brands."
  path="/portfolio"
>
  <header class="page-header page-header--portfolio" data-animate>
    <div class="container">
      <span class="section-label">Portfolio</span>
      <h1 class="section-title">
        <span class="accent-script">crafted</span> edits
      </h1>
      <p class="section-subtitle">
        Sample work and practice edits — honest portfolio pieces, no inflated claims.
      </p>
    </div>
  </header>

  <section class="section portfolio-showcase-section">
    <div class="container">
      <PortfolioGrid items={portfolioItems} layout="showcase" />
    </div>
  </section>

  <ContactCTA />
</BaseLayout>