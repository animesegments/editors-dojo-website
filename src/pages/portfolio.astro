---
import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioGrid from '../components/PortfolioGrid.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { portfolioItems } from '../data/portfolio';
---

<BaseLayout
  title="editorsdojo | Portfolio"
  description="View sample edits and practice pieces by editorsdojo — honest short-form video editing for personal brands."
  path="/portfolio"
>
  <header class="page-header page-header--portfolio" data-animate>
    <div class="container">
      <div class="portfolio-intro">
        <span class="section-label">Portfolio</span>
        <h1 class="section-title">Crafted edits</h1>
        <div class="portfolio-intro-copy">
          <p class="section-subtitle">
            A simple look at my editing style, sample work, and practice edits.
          </p>
          <p class="section-supporting">
            This portfolio is honest. No fake numbers. No inflated claims. Just real work that shows how I cut, pace, and shape content.
          </p>
          <p class="section-supporting">
            Each edit is made with one goal: make the video feel cleaner, sharper, and easier to watch.
          </p>
        </div>
      </div>
    </div>
  </header>

  <section class="section portfolio-showcase-section">
    <div class="container">
      <PortfolioGrid items={portfolioItems} layout="showcase" />
    </div>
  </section>

  <ContactCTA />
</BaseLayout>