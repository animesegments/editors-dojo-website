---
import { vimeoEmbedUrl } from '../data/portfolio';

interface Props {
  title: string;
  description: string;
  vimeoId: string;
  index?: number;
}

const { title, description, vimeoId, index = 0 } = Astro.props;
const iframeSrc = vimeoEmbedUrl(vimeoId);
---

<article class="style-card" style={`--i: ${index}`} data-animate>
  <div class="style-card-video">
    <div class="video-embed">
      <iframe
        src={iframeSrc}
        allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        title={title}
        loading="lazy"
      ></iframe>
    </div>
  </div>
  <div class="style-card-body">
    <span class="style-card-label">Editing Style</span>
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</article>