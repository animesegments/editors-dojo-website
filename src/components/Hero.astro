---
import { SITE } from '../data/site';
---

<section class="hero">
  <div class="hero-bg-accent" aria-hidden="true"></div>
  <div class="container hero-grid">
    <div class="hero-logo-wrap">
      <div class="hero-logo-glow" aria-hidden="true"></div>
      <div class="hero-logo-backdrop" aria-hidden="true"></div>
      <img
        src={SITE.logo}
        alt="editorsdojo logo"
        class="hero-logo-img brand-logo"
        width="280"
        height="280"
      />
    </div>

    <div class="hero-content">
      <p class="hero-eyebrow">Freelance Short-Form Video Editor</p>
      <h1 class="hero-title">
        <span class="accent-script">Cinematic</span> Short-Form Edits for Personal Brands That Want to Look Premium
      </h1>
      <p class="hero-subtitle">
        editorsdojo helps creators, coaches, entrepreneurs, and personal brands transform raw footage into clean, cinematic short-form videos built for attention, clarity, and trust.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary">Book a Free Sample Edit</a>
        <a href="/portfolio" class="btn btn-secondary">View Portfolio</a>
      </div>
    </div>
  </div>
</section>