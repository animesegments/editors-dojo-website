---
const steps = [
  {
    num: '01',
    title: 'Send a Raw Clip',
    description: 'Share unedited footage and a brief on what you need.',
  },
  {
    num: '02',
    title: 'Review the Style',
    description: 'We align on pacing, tone, and the look you want.',
  },
  {
    num: '03',
    title: 'Receive a Sample Edit',
    description: 'See the editing approach applied to your content — free.',
  },
  {
    num: '04',
    title: 'Collaborate',
    description: 'If it fits, we move forward on your ongoing content needs.',
  },
];
---

<div class="process-grid">
  {steps.map((step, i) => (
    <div class="process-step" style={`--i: ${i}`}>
      <span class="step-num">{step.num}</span>
      <h3>{step.title}</h3>
      <p>{step.description}</p>
    </div>
  ))}
</div>