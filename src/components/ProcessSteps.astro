---
const steps = [
  {
    num: '01',
    title: 'Send a Raw Clip',
    description: 'Share your unedited footage and tell me what you want the video to feel like.',
  },
  {
    num: '02',
    title: 'Set the Direction',
    description: 'We choose the editing style, pace, mood, and overall look.',
  },
  {
    num: '03',
    title: 'Get a Sample Edit',
    description: 'I create a short free sample so you can see how your content could look.',
  },
  {
    num: '04',
    title: 'Move Forward',
    description: 'If you like the style, we can work together on more videos.',
  },
];
---

<div class="process-grid">
  {steps.map((step, i) => (
    <div class="process-step" style={`--i: ${i}`}>
      <span class="step-num">{step.num}</span>
      <h3>{step.title}</h3>
      <p>{step.description}</p>
    </div>
  ))}
</div>