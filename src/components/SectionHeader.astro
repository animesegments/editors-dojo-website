---
interface Props {
  label: string;
  title: string;
  subtitle?: string;
  supporting?: string;
  centered?: boolean;
}

const { label, title, subtitle, supporting, centered = false } = Astro.props;
---

<div class:list={['section-header', { centered, 'text-center': centered }]}>
  <span class="section-label">{label}</span>
  <h2 class="section-title" set:html={title} />
  {subtitle && <p class="section-subtitle">{subtitle}</p>}
  {supporting && <p class="section-supporting">{supporting}</p>}
</div>