---
import ThemeToggle from './ThemeToggle.astro';
import Logo from './Logo.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const links = [
  { href: '/', label: 'Home', icon: '〆', isHome: true },
  { href: '/portfolio', label: 'Portfolio', icon: null, isHome: false },
  { href: '/services', label: 'Services', icon: null, isHome: false },
  { href: '/about', label: 'About', icon: null, isHome: false },
  { href: '/contact', label: 'Contact', icon: null, isHome: false },
];
---

<header class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo" aria-label="editorsdojo home">
      <Logo class="brand-logo nav-logo-img" width={180} height={180} eager />
    </a>

    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" id="nav-toggle">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="nav-pills-wrap" aria-label="Main navigation">
      <ul class="nav-pills" id="nav-links">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                'nav-pill',
                { 'nav-pill-home': link.isHome },
                { active: currentPath === link.href },
              ]}
            >
              {link.isHome && <span class="nav-pill-mark" aria-hidden="true">{link.icon}</span>}
              <span class="nav-pill-label">{link.label}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav-actions">
      <ThemeToggle />
      <a href="/contact" class="btn btn-primary nav-cta-desktop">Book a Free Sample Edit</a>
    </div>
  </div>

  <div class="nav-mobile-panel" id="nav-mobile-panel" hidden>
    <ul class="nav-mobile-pills">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'nav-pill',
              { 'nav-pill-home': link.isHome },
              { active: currentPath === link.href },
            ]}
          >
            {link.isHome && <span class="nav-pill-mark" aria-hidden="true">{link.icon}</span>}
            <span class="nav-pill-label">{link.label}</span>
          </a>
        </li>
      ))}
      <li class="nav-mobile-theme">
        <ThemeToggle />
      </li>
      <li class="nav-mobile-cta">
        <a href="/contact" class="btn btn-primary btn-block">Book a Free Sample Edit</a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const panel = document.getElementById('nav-mobile-panel');

  toggle?.addEventListener('click', () => {
    const isOpen = panel?.toggleAttribute('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.classList.toggle('open', isOpen);
    document.body.classList.toggle('nav-open', isOpen);
  });

  panel?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      panel.setAttribute('hidden', '');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.classList.remove('open');
      document.body.classList.remove('nav-open');
    });
  });
</script>