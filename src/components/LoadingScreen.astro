---
import '../styles/loader-fonts.css';
import { SITE } from '../data/site';

const LOADER_MS = 1500;
---

<div class="loader" id="site-loader" aria-hidden="false" aria-label="Loading editorsdojo">
  <div class="loader-backdrop"></div>
  <div class="loader-inner">
    <div class="loader-brand">
      <div class="loader-logo-wrap">
        <div class="loader-logo-ring" aria-hidden="true"></div>
        <div class="loader-logo-glow" aria-hidden="true"></div>
        <img src={SITE.logo} alt="" class="loader-logo" width="280" height="280" />
      </div>

      <p class="loader-wordmark" aria-label="editorsdojo">
        <span class="loader-wordmark-sans">editors</span><span class="loader-wordmark-script">dojo</span>
      </p>

      <div class="loader-divider" aria-hidden="true"><span></span></div>

      <p class="loader-tagline">
        <span class="loader-tagline-script">crafted</span>
        <span class="loader-tagline-sans">with discipline</span>
      </p>
    </div>

    <div class="loader-bar">
      <div class="loader-bar-fill"></div>
    </div>
  </div>
</div>

<script define:vars={{ loaderMs: LOADER_MS }}>
  const loader = document.getElementById('site-loader');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const duration = prefersReduced ? 0 : loaderMs;

  function hideLoader() {
    if (!loader) return;
    loader.classList.add('loader-out');
    loader.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('is-loading');
    setTimeout(() => loader.remove(), prefersReduced ? 0 : 400);
  }

  document.body.classList.add('is-loading');

  function startTimer() {
    setTimeout(hideLoader, duration);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', startTimer);
  } else {
    startTimer();
  }
</script>