---
import '../styles/loader-fonts.css';
import Logo from './Logo.astro';

const LOADER_MS = 750;
const FADE_MS = 320;
---

<div class="loader" id="site-loader" aria-hidden="false" aria-label="Loading editorsdojo">
  <div class="loader-backdrop"></div>
  <div class="loader-inner">
    <div class="loader-brand">
      <div class="loader-logo-wrap">
        <Logo class="loader-logo brand-logo" width={180} height={180} eager />
      </div>

      <div class="loader-timeline" aria-hidden="true">
        <span class="loader-timeline-line"></span>
        <span class="loader-timeline-slash"></span>
      </div>

      <p class="loader-kanji" aria-hidden="true">編集道場</p>
      <p class="loader-tagline-minimal">edit with discipline.</p>
    </div>
  </div>
</div>

<script define:vars={{ loaderMs: LOADER_MS, fadeMs: FADE_MS }}>
  const loader = document.getElementById('site-loader');
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const duration = prefersReduced ? 0 : loaderMs;
  const fade = prefersReduced ? 0 : fadeMs;
  let hidden = false;
  let minElapsed = prefersReduced;
  let pageLoaded = document.readyState === 'complete';

  function hideLoader() {
    if (!loader || hidden) return;
    hidden = true;
    loader.classList.add('loader-out');
    loader.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('is-loading');
    setTimeout(() => loader.remove(), fade);
  }

  function tryHide() {
    if (minElapsed && pageLoaded) hideLoader();
  }

  document.body.classList.add('is-loading');

  if (prefersReduced) {
    hideLoader();
  } else {
    setTimeout(() => {
      minElapsed = true;
      tryHide();
    }, duration);

    if (!pageLoaded) {
      window.addEventListener('load', () => {
        pageLoaded = true;
        tryHide();
      }, { once: true });
    }
  }
</script>